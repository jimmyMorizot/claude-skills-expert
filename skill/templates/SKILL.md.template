---
name: {{NAME}}
# Skill identifier. Lowercase, digits, and hyphens only, max 64 characters.
# Must match the skill directory name. If omitted, the directory name is used.

description: {{DESCRIPTION}}
# What the skill does and when to use it. MUST be under 250 characters.
# Front-load the key use case with keywords users would naturally say.
# Do not summarize the skill's internal workflow here.

argument-hint: {{ARGUMENT_HINT}}
# Autocomplete hint shown in the slash-command menu.
# Examples: [filename], [issue-number], [block-name] [category]
# Remove this field if the skill takes no arguments.

allowed-tools: {{ALLOWED_TOOLS}}
# Tools pre-approved for use without permission prompts when this skill is active.
# Space-separated string or YAML list. Scope to the strict minimum.
# This pre-approves only — it does NOT restrict available tools.
# Remove this field if no pre-approval is needed.

paths: {{PATHS}}
# Glob patterns limiting auto-activation to matching files.
# Comma-separated string or YAML list. Examples: src/**/*.ts, *.py, wp-content/**
# Remove this field if the skill should activate on conversation context alone.

# Advanced optional fields — uncomment only if needed:
# disable-model-invocation: true   # Prevent auto-invocation; user must call /skill-name manually.
# user-invocable: false            # Hide from / menu; Claude can still auto-invoke it.
# model: claude-opus-4-6          # Override the model used when this skill is active.
# effort: high                    # Effort level: low | medium | high | max (max = Opus 4.6 only).
# context: fork                   # Execute in a forked subagent instead of inline.
# agent: Explore                  # Subagent type when context: fork (e.g. Explore, general-purpose).
# hooks: ...                      # Lifecycle hooks scoped to this skill's session.
# shell: bash                     # Shell for injection blocks: bash (default) | powershell.
